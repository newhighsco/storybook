{
  "name": "@newhighsco/storybook",
  "description": "New High Score Storybook addons and presets",
  "author": "New High Score",
  "license": "ISC",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/newhighsco/storybook.git"
  },
  "homepage": "https://github.com/newhighsco/storybook#readme",
  "bugs": {
    "url": "https://github.com/newhighsco/storybook/issues"
  },
  "packageManager": "yarn@4.17.1",
  "type": "module",
  "scripts": {
    "prestart": "yarn build",
    "start": "storybook dev --port 6006 --docs",
    "prepare": "husky",
    "build": "yarn workspaces foreach --all run build",
    "prebuild:storybook": "yarn build",
    "build:storybook": "storybook build --output-dir build --docs --quiet --webpack-stats-json",
    "pretest": "yarn lint",
    "test": "jest --runInBand",
    "test:list": "jest --listTests",
    "snapshot": "chromatic --storybook-build-dir build --auto-accept-changes main --exit-once-uploaded --only-changed",
    "lint": "concurrently 'yarn:lint:*'",
    "lint:css": "stylelint --cache --ignore-path .gitignore '**/*.?(s)css'",
    "lint:js": "eslint --cache .",
    "format": "concurrently 'yarn:format:*'",
    "format:css": "yarn lint:css --fix",
    "format:js": "yarn lint:js --fix"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.1",
    "@newhighsco/chipset": "7.4.0",
    "@newhighsco/commitlint-config": "1.3.4",
    "@newhighsco/editor-config": "1.2.0",
    "@newhighsco/eslint-config": "7.1.20",
    "@newhighsco/prettier-config": "2.3.12",
    "@newhighsco/release-config": "1.5.3",
    "@newhighsco/stylelint-config": "4.0.52",
    "@newhighsco/ts-config": "1.2.2",
    "@newhighsco/yarn-plugin-preset": "1.1.4",
    "@qiwi/multi-semantic-release": "7.1.2",
    "@storybook/react-webpack5": "10.5.0",
    "@swc/core": "1.15.43",
    "@swc/jest": "0.2.39",
    "@types/jest": "30.0.0",
    "chromatic": "18.0.1",
    "concurrently": "10.0.3",
    "eslint": "10.7.0",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "jest-junit": "17.0.0",
    "prettier": "3.9.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "semantic-release": "25.0.6",
    "storybook": "10.5.0",
    "stylelint": "17.14.0",
    "tsdown": "0.22.6",
    "typescript": "6.0.3",
    "webpack": "5.108.4"
  },
  "commitlint": {
    "extends": [
      "@newhighsco"
    ]
  },
  "multi-release": {
    "sequentialInit": true
  },
  "prettier": "@newhighsco/prettier-config",
  "release": {
    "extends": "@newhighsco/release-config"
  },
  "stylelint": {
    "extends": [
      "@newhighsco/stylelint-config"
    ]
  }
}
